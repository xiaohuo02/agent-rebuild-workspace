# Copy this file to backend/.env and fill real values.
# Never commit backend/.env.

# App
REBUILD_APP_NAME="Agent Rebuild Workspace"
REBUILD_API_PREFIX="/api"
REBUILD_CORS_ORIGINS='["http://localhost:5173"]'

# Model provider: fake, mimo, deepseek, ollama
REBUILD_LLM_PROVIDER="fake"

# MiMo
REBUILD_MIMO_API_KEY=""
REBUILD_MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
REBUILD_MIMO_MODEL="mimo-v2.5-pro"

# DeepSeek
REBUILD_DEEPSEEK_API_KEY=""
REBUILD_DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
REBUILD_DEEPSEEK_MODEL="deepseek-chat"

# Ollama
REBUILD_OLLAMA_BASE_URL="http://127.0.0.1:11434"
REBUILD_OLLAMA_MODEL="qwen3:4b"
REBUILD_OLLAMA_EMBEDDING_MODEL="quentinz/bge-large-zh-v1.5:f16"

# MySQL
REBUILD_MYSQL_DSN=""

# Redis
REBUILD_REDIS_URL="redis://127.0.0.1:6380/0"

# Neo4j
REBUILD_NEO4J_URI="bolt://127.0.0.1:7687"
REBUILD_NEO4J_USERNAME="neo4j"
REBUILD_NEO4J_PASSWORD=""
REBUILD_NEO4J_DATABASE="neo4j"

# Runtime
REBUILD_LOG_LEVEL="INFO"
